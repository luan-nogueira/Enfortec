rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função que verifica se o usuário é administrador
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "luanmnogueira@gmail.com" || 
        request.auth.token.email == "enfortec@admin.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Digital products - public read, admin write only
    match /digital_products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Prizes catalog - public read, authenticated write
    match /prizes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Used products - public read, authenticated write
    match /used_products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users - administradores podem ver/editar todos, usuários podem ver/editar os próprios dados
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Referrals - authenticated read/write
    match /referrals/{doc} {
      allow read, write: if request.auth != null;
    }

    // Redemptions - authenticated read/write
    match /redemptions/{doc} {
      allow read, write: if request.auth != null;
    }

    // Chats - authenticated read/write
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Banners Promos - leitura pública, escrita autenticada
    match /promos/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Promotions deals - leitura pública, escrita autenticada
    match /promocoes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
