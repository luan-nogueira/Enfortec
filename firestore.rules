rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Digital products - public read, admin write only
    match /digital_products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Prizes catalog - public read, authenticated write
    match /prizes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Used products - public read, authenticated write
    match /used_products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users - can only read/write own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Referrals - authenticated read/write
    match /referrals/{doc} {
      allow read, write: if request.auth != null;
    }

    // Redemptions - authenticated read/write
    match /redemptions/{doc} {
      allow read, write: if request.auth != null;
    }

    // Chats - authenticated read/write
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Banners Promos - public read, authenticated write
    match /promos/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Promotions deals - public read, authenticated write
    match /promocoes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
